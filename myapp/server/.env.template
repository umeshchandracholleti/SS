# Backend Environment Configuration Template
# Copy this file to .env in production
# DO NOT commit .env to Git!

# ===========================================
# Server Configuration
# ===========================================

# Server port (Hostinger Node.js apps typically use 4000 or assigned port)
PORT=4000

# Node environment
NODE_ENV=production

# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?sslmode=require

# Option 1: Supabase PostgreSQL (Recommended - already configured)
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# Option 2: Hostinger PostgreSQL
# DATABASE_URL=postgresql://hostinger_user:password@localhost:5432/yourdatabase

# ===========================================
# Supabase Configuration (if using Supabase)
# ===========================================

SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# JWT Configuration
# ===========================================

# JWT secret for token signing/verification (MUST be at least 32 characters)
# Generate a secure random string: openssl rand -base64 48
JWT_SECRET=change-this-to-a-very-long-random-string-minimum-32-characters

# JWT expiration time
JWT_EXPIRES_IN=7d

# ===========================================
# CORS Configuration
# ===========================================

# Frontend URL for CORS (your Hostinger domain)
FRONTEND_URL=https://yourdomain.com

# Additional allowed origins (comma-separated if multiple)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# Optional: Email Configuration
# ===========================================

# SMTP settings (if using email notifications)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=noreply@yourdomain.com

# ===========================================
# Optional: File Upload Configuration
# ===========================================

# Maximum file upload size (in MB)
# MAX_FILE_SIZE=10

# Upload directory
# UPLOAD_DIR=./uploads

# ===========================================
# Optional: Logging & Monitoring
# ===========================================

# Log level (error, warn, info, debug)
# LOG_LEVEL=info

# Sentry DSN for error tracking
# SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxx

# ===========================================
# Optional: Payment Gateway (if using)
# ===========================================

# Razorpay (example)
# RAZORPAY_KEY_ID=rzp_live_xxxxx
# RAZORPAY_KEY_SECRET=xxxxx

# ===========================================
# Deployment Instructions
# ===========================================

# 1. Copy this file to .env in your backend directory
# 2. Fill in all required values (marked with [YOUR_...])
# 3. Generate a secure JWT_SECRET (at least 32 characters)
# 4. Update DATABASE_URL with your actual database credentials
# 5. Set FRONTEND_URL to your Hostinger domain
# 6. Upload to Hostinger Node.js application directory
# 7. In Hostinger Node.js panel, add these as environment variables
#    (Alternative to .env file - more secure for production)
# 8. Restart Node.js application

# ===========================================
# Security Notes
# ===========================================

# - NEVER commit .env file to Git
# - Use strong, random values for JWT_SECRET
# - Keep database credentials secure
# - Regularly rotate sensitive credentials
# - Use HTTPS in production (enabled by default in Hostinger)
# - Enable Hostinger firewall for additional security
