# Frontend Environment Configuration Template
# Copy this file to .env.production (for production build)
# DO NOT commit .env.production to Git!

# ===========================================
# API Configuration
# ===========================================

# Backend API URL - Update with your actual Hostinger domain
# Examples:
#   - Main domain with /api path: https://yourdomain.com/api
#   - API subdomain: https://api.yourdomain.com
#   - During development: http://localhost:4000
VITE_API_URL=https://yourdomain.com/api

# ===========================================
# Optional: Analytics & Monitoring
# ===========================================

# Google Analytics (if using)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry Error Tracking (if using)
# VITE_SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxx

# ===========================================
# Optional: Feature Flags
# ===========================================

# Enable debug mode (set to 'false' in production)
# VITE_DEBUG_MODE=false

# ===========================================
# Build Instructions
# ===========================================

# 1. Copy this file to .env.production
# 2. Update VITE_API_URL with your actual Hostinger domain
# 3. Run: npm run build
# 4. Upload dist/ contents to Hostinger public_html
