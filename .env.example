# =============================================================
#  Sai Scientifics — Full-Stack Environment Reference
#  Copy this file to myapp/server/.env and fill in real values
#  NEVER commit the real .env file
# =============================================================

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Database (PostgreSQL) ─────────────────────────────────────
# For Hostinger PostgreSQL use the connection string from hPanel → Databases
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# ── Security ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=7d
SESSION_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_STRING

# ── CORS (comma-separated for multiple origins) ───────────────
CORS_ORIGIN=https://saiscientificas.com,https://www.saiscientificas.com

# ── Frontend URL (used in emails / redirects) ─────────────────
FRONTEND_URL=https://saiscientificas.com

# ── Razorpay ──────────────────────────────────────────────────
# Live keys from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
# Webhook secret from: https://dashboard.razorpay.com → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── Email (Gmail SMTP with App Password) ─────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=sales@saiscientificas.com
# Create app password at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD
EMAIL_FROM=Sai Scientificas <sales@saiscientificas.com>

# ── WhatsApp / SMS (Twilio — optional) ───────────────────────
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Company Details ───────────────────────────────────────────
COMPANY_NAME=Sai Scientificas
COMPANY_EMAIL=sales@saiscientificas.com
COMPANY_PHONE=+91XXXXXXXXXX
COMPANY_ADDRESS=Your Address Here
COMPANY_GSTIN=YOUR_GSTIN

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Frontend (Vite build — set before running npm run build) ──
# Only needed if backend is on a different domain/subdomain
# Leave empty to use same-origin /api routing (recommended for Hostinger)
VITE_API_URL=
